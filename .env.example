# ============================================================
# LaunchPad — Environment Variables Reference
# Copy this file to .env and fill in the real values
# ============================================================

# ---- Clerk Authentication ----
# 1. Go to: https://dashboard.clerk.com
# 2. Click "Create Application" → name it LaunchPad → choose Email/Password
# 3. Go to API Keys → copy Publishable Key and Secret Key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routes (do not change these)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret
# 4. Go to: Clerk Dashboard → Webhooks → Add Endpoint
#    URL: https://launchpad-clubers.vercel.app/api/webhooks/clerk
#    Events: Check "user.created"
#    Copy the Signing Secret shown
WEBHOOK_SECRET=whsec_...

# ---- MongoDB ----
# 1. Go to: https://cloud.mongodb.com → Create a FREE M0 cluster
# 2. Database Access → Add user (username + password)
# 3. Network Access → Add IP → Allow access from anywhere (0.0.0.0/0)
# 4. Clusters → Connect → Drivers → copy the connection string
#    Replace <password> with your actual password
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/launchpad?retryWrites=true&w=majority

# ---- Supabase Storage ----
# 1. Go to: https://app.supabase.com → New Project
# 2. Project Settings → API → copy Project URL and service_role key
# 3. Storage → New Bucket → Name: "resumes" → Public: YES ✓
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Anthropic Claude API ----
# 1. Go to: https://console.anthropic.com
# 2. API Keys → Create Key → copy it
ANTHROPIC_API_KEY=sk-ant-api03-...
